# ─── Configurações de Banco de Dados ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinicafemina
DB_USER=postgres
DB_PASS=coloque_sua_senha_aqui

# ─── Configurações de Segurança e JWT ───
JWT_SECRET=coloque_um_secret_seguro_e_longo_aqui
APP_ENCRYPTION_KEY_V1=coloque_uma_chave_hex_de_32_bytes_aqui

# ─── Configurações do RabbitMQ ───
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# ─── Configurações Meta WhatsApp Cloud API ───
META_WHATSAPP_VERIFY_TOKEN=seu_verify_token_personalizado
META_WHATSAPP_APP_SECRET=seu_app_secret_aqui
META_WHATSAPP_ACCESS_TOKEN=seu_access_token_aqui
META_WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui

# ─── Configurações Integração Darwin API ───
DARWIN_API_URL=https://sandbox.api.darwin.health/v1
DARWIN_API_TOKEN=cole_seu_token_jwt_do_darwin_aqui
DARWIN_SYNC_CRON=0 0/15 * * * ?
DARWIN_SYNC_PAGE_SIZE=100
DARWIN_SYNC_ENABLED=true
